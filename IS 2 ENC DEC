def encrypt(message, key):
    cipher = "" 

    for col in range(key):
        pointer = col

        while pointer < len(message):
            cipher += message[pointer]
            pointer += key

    return cipher


# Function for Decryption
def decrypt(cipher, key):
    msg_len = len(cipher)

    num_cols = msg_len // key
    if msg_len % key != 0:
        num_cols += 1

    num_rows = key
    num_shaded_boxes = (num_cols * num_rows) - msg_len

    plain_text = [""] * num_cols

    col = 0
    row = 0

    for symbol in cipher:
        plain_text[col] += symbol
        col += 1

        if (col == num_cols) or (
            col == num_cols - 1 and row >= num_rows - num_shaded_boxes
        ):
            col = 0
            row += 1

    return "".join(plain_text)



message = input("Enter the message: ")

try:
    key = int(input("Enter the key value: "))

    encrypted_text = encrypt(message, key)
    print("\nEncrypted Message:", encrypted_text)

    decrypted_text = decrypt(encrypted_text, key)
    print("Decrypted Message:", decrypted_text)

except ValueError:
    print("Please enter a valid numeric key.")
